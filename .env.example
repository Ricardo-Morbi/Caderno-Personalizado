# ─── VARIÁVEIS DE AMBIENTE — EXEMPLO ────────────────────────────────────────
# Copie para .env.local e preencha os valores.
# NUNCA commite .env.local no git — já está no .gitignore.
#
# ⚠️ REGRA DE SEGURANÇA: NEXT_PUBLIC_ expõe a variável ao browser (bundle público).
# Use NEXT_PUBLIC_ APENAS para dados intencionalmente públicos (URL do site).
# Para secrets (tokens, API keys), use nomes SEM prefixo e acesse só no servidor.
# ─────────────────────────────────────────────────────────────────────────────

# URL pública do site — seguro como NEXT_PUBLIC_ (é dado público)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── INTEGRAÇÕES FUTURAS ─────────────────────────────────────────────────────
# ⚠️ Removido o prefixo NEXT_PUBLIC_ — são secrets, acessar só em Server Actions.

# Email de contato para receber pedidos (futuro)
# CONTATO_EMAIL=sua@email.com

# Integração com WhatsApp Business API (futuro)
# WHATSAPP_NUMERO=5511999999999
# WHATSAPP_TOKEN=seu_token_aqui
